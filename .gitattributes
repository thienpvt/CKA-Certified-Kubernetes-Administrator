# Auto detect text files and normalise line endings to LF
* text=auto eol=lf

# Shell scripts must always use LF
*.sh text eol=lf

# Windows-specific files use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.gif binary
*.ico binary

# cka-sim test harness — extension-less bin scripts and JSON fixtures
cka-sim/tests/bin/* text eol=lf
cka-sim/tests/fixtures/**/*.json text eol=lf
