{
  "kind": "Deployment",
  "apiVersion": "apps/v1",
  "metadata": {
    "name": "q07-app",
    "namespace": "cka-sim-workloads-scheduling-07",
    "labels": {"app": "q07-app"}
  },
  "spec": {
    "replicas": 1,
    "selector": {"matchLabels": {"app": "q07-app"}},
    "template": {
      "metadata": {"labels": {"app": "q07-app"}},
      "spec": {
        "initContainers": [
          {
            "name": "log-tailer",
            "image": "busybox:1.36",
            "restartPolicy": "Always",
            "command": ["sh","-c","while true; do echo q07-log $(date) >> /shared/app.log; sleep 1; done"],
            "volumeMounts": [{"name": "shared", "mountPath": "/shared"}]
          }
        ],
        "containers": [
          {
            "name": "app",
            "image": "nginx:1.27",
            "volumeMounts": [{"name": "shared", "mountPath": "/shared"}]
          }
        ],
        "volumes": [{"name": "shared", "emptyDir": {}}]
      }
    }
  }
}
