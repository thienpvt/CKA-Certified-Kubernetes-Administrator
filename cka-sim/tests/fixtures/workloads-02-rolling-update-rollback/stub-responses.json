{
  "kind": "Deployment",
  "apiVersion": "apps/v1",
  "metadata": {
    "name": "web",
    "namespace": "cka-sim-workloads-scheduling-02",
    "generation": 3,
    "labels": {"app": "web"}
  },
  "spec": {
    "replicas": 2,
    "strategy": {
      "type": "RollingUpdate",
      "rollingUpdate": {"maxUnavailable": 0, "maxSurge": 1}
    },
    "selector": {"matchLabels": {"app": "web"}},
    "template": {
      "metadata": {"labels": {"app": "web"}},
      "spec": {
        "containers": [
          {
            "name": "app",
            "image": "nginx:1.25",
            "ports": [{"containerPort": 80}]
          }
        ]
      }
    }
  }
}
