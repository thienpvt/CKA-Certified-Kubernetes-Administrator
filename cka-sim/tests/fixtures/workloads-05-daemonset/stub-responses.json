{
  "kind": "DaemonSet",
  "apiVersion": "apps/v1",
  "metadata": {
    "name": "q05-node-agent",
    "namespace": "cka-sim-workloads-scheduling-05",
    "labels": {"app": "q05-node-agent"}
  },
  "spec": {
    "selector": {"matchLabels": {"app": "q05-node-agent"}},
    "template": {
      "metadata": {"labels": {"app": "q05-node-agent"}},
      "spec": {
        "serviceAccountName": "q05-node-agent-sa",
        "tolerations": [
          {"key": "node-role.kubernetes.io/control-plane", "operator": "Exists", "effect": "NoSchedule"},
          {"key": "node-role.kubernetes.io/control-plane", "operator": "Exists", "effect": "NoExecute"}
        ],
        "containers": [
          {
            "name": "agent",
            "image": "busybox:1.36",
            "command": ["sh", "-c", "sleep 3600"],
            "resources": {"requests": {"cpu": "25m", "memory": "32Mi"}}
          }
        ]
      }
    }
  },
  "status": {
    "desiredNumberScheduled": 3,
    "currentNumberScheduled": 3,
    "numberReady": 3
  }
}
