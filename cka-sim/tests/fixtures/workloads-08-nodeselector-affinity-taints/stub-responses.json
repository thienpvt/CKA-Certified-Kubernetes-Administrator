{
  "kind": "Deployment",
  "apiVersion": "apps/v1",
  "metadata": {
    "name": "q08-gpu-sim",
    "namespace": "cka-sim-workloads-scheduling-08",
    "labels": {"app": "q08-gpu-sim"}
  },
  "spec": {
    "replicas": 2,
    "selector": {"matchLabels": {"app": "q08-gpu-sim"}},
    "template": {
      "metadata": {"labels": {"app": "q08-gpu-sim"}},
      "spec": {
        "tolerations": [
          {"key": "gpu", "operator": "Equal", "value": "true", "effect": "NoSchedule"}
        ],
        "affinity": {
          "nodeAffinity": {
            "requiredDuringSchedulingIgnoredDuringExecution": {
              "nodeSelectorTerms": [
                {"matchExpressions": [{"key": "gpu", "operator": "In", "values": ["true"]}]}
              ]
            }
          }
        },
        "containers": [
          {
            "name": "app",
            "image": "busybox:1.36",
            "command": ["sh","-c","sleep 3600"],
            "resources": {"requests": {"cpu": "25m", "memory": "32Mi"}}
          }
        ]
      }
    }
  }
}
