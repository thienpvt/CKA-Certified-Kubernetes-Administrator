{
  "kind": "NetworkPolicy",
  "apiVersion": "networking.k8s.io/v1",
  "metadata": {"name": "allow-with-dns", "namespace": "cka-sim-test"},
  "spec": {
    "podSelector": {},
    "policyTypes": ["Egress"],
    "egress": [
      {"to": [{"ipBlock": {"cidr": "10.0.0.0/8"}}], "ports": [{"protocol": "TCP", "port": 443}]},
      {"to": [{"namespaceSelector": {"matchLabels": {"kubernetes.io/metadata.name": "kube-system"}}}], "ports": [{"protocol": "UDP", "port": 53}]}
    ]
  }
}
