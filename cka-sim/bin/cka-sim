#!/bin/bash
# cka-sim — CKA Exam Simulator dispatcher
# Usage: cka-sim <command> [args]
#
# This is the only file that needs to be on $PATH. Subcommands live in
# cka-sim/lib/cmd/*.sh and are invoked via exec so each one is independently
# testable and doesn't pollute this process.

set -euo pipefail

# Resolve symlinks so invocation via /usr/local/bin/cka-sim still finds lib/.
CKA_SIM_ROOT="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)"
export CKA_SIM_ROOT

# shellcheck source=../lib/colors.sh disable=SC1091
source "$CKA_SIM_ROOT/lib/colors.sh"
# shellcheck source=../lib/log.sh disable=SC1091
source "$CKA_SIM_ROOT/lib/log.sh"

cmd="${1:-help}"

case "$cmd" in
  -h|--help|help)
    shift 2>/dev/null || true
    exec "$CKA_SIM_ROOT/lib/cmd/help.sh" "$@"
    ;;
  bootstrap|doctor|list|version|drill|exam|score)
    shift
    cmd_script="$CKA_SIM_ROOT/lib/cmd/$cmd.sh"
    [[ -f "$cmd_script" ]] || die "internal: missing $cmd_script"
    [[ -x "$cmd_script" ]] || die "internal: $cmd_script is not executable"
    exec "$cmd_script" "$@"
    ;;
  *)
    die "unknown subcommand: $cmd — run 'cka-sim --help'"
    ;;
esac
